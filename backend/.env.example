# Copy to .env. All optional in Phase 0 (pipeline runs in mock mode without a key).
LOOKBOOK_GEMINI_API_KEY=
LOOKBOOK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# S3 object storage (optional). Set all three to store assets in S3 instead of
# local disk. Leave blank to use local disk (served at /media).
LOOKBOOK_S3_BUCKET=
LOOKBOOK_S3_REGION=us-east-1
LOOKBOOK_S3_ACCESS_KEY_ID=
LOOKBOOK_S3_SECRET_ACCESS_KEY=
# Optional: for S3-compatible providers (Cloudflare R2 / Backblaze B2)
LOOKBOOK_S3_ENDPOINT_URL=
# Optional: CDN / custom domain in front of the bucket
LOOKBOOK_S3_PUBLIC_BASE_URL=
